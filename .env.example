# WC26 environment — copy to `.env` and fill in.
# Public vars are bundled into the app (EXPO_PUBLIC_ prefix required by Expo).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — only used by the live-score client fallback (the edge function uses
# its own secret). Leave blank to keep live sync inert.
EXPO_PUBLIC_APIFOOTBALL_KEY=

# ───────────── server-only (NOT bundled) — used by scripts/seed.ts ─────────────
SUPABASE_SERVICE_ROLE_KEY=
